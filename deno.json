{
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-read=public --allow-env src/server.ts",
    "start": "deno run --allow-net --allow-read=public --allow-env src/server.ts",
    "test": "deno test -A --coverage=coverage",
    "coverage": "deno coverage coverage --lcov > coverage.lcov",
    "fmt": "deno run -A npm:prettier@^3 --write .",
    "fmt:check": "deno run -A npm:prettier@^3 --check .",
    "lint": "deno run -A npm:eslint@^9 --ext .ts,.tsx .",
    "lint:fix": "deno run -A npm:eslint@^9 --ext .ts,.tsx . --fix",
    "knip": "deno run -A npm:knip@^5",
    "build": "deno compile --allow-net --allow-read=public --allow-env --output bin/os-ubq-fi src/server.ts"
  },
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": true
  },
  "imports": {
    "@/": "./src/",
    "@std/http/file-server": "jsr:@std/http@^1/file-server",
    "@std/assert": "jsr:@std/assert@^1"
  }
}
