{
  "tasks": {
    "dev": "sh -c 'deno run -A npm:esbuild src/web/app.ts --bundle --platform=browser --format=esm --target=es2019 --sourcemap=external --outfile=public/assets/app.js --watch & deno run --watch --allow-net --allow-read=public --allow-env src/server.ts'",
    "dev:server": "deno run --watch --allow-net --allow-read=public --allow-env src/server.ts",
    "dev:client": "deno run -A npm:esbuild src/web/app.ts --bundle --platform=browser --format=esm --target=es2019 --sourcemap=external --outfile=public/assets/app.js --watch",
    "build:client": "deno run -A npm:esbuild src/web/app.ts --bundle --platform=browser --format=esm --target=es2019 --sourcemap=external --minify --outfile=public/assets/app.js",
    "start": "deno task build:client && deno run --allow-net --allow-read=public --allow-env src/server.ts",
    "test": "deno test -A --coverage=coverage",
    "coverage": "deno coverage coverage --lcov > coverage.lcov",
    "fmt": "deno run -A npm:prettier@^3 --write .",
    "fmt:check": "deno run -A npm:prettier@^3 --check .",
    "lint": "deno run -A npm:eslint@^9 --ext .ts,.tsx .",
    "lint:fix": "deno run -A npm:eslint@^9 --ext .ts,.tsx . --fix",
    "knip": "deno run -A npm:knip@^5 --files --exports",
    "build": "deno task build:client && deno compile --allow-net --allow-read=public --allow-env --output bin/os-ubq-fi src/server.ts"
  },
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": true
  },
  "imports": {
    "@/": "./src/",
    "@eslint/js": "npm:@eslint/js@^9.37.0",
    "@std/http/file-server": "jsr:@std/http@^1/file-server",
    "@std/assert": "jsr:@std/assert@^1",
    "typescript-eslint": "npm:typescript-eslint@^8.46.0"
  }
}
